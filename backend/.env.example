# Cổng chạy API
PORT=3000

# Prisma + MongoDB — LUÔN phải có TÊN DATABASE trong path (vd /timelinedb), nếu không sẽ lỗi
# "empty database name not allowed".
#
# 1) Docker local (single-node replica set): cần directConnection=true
# DATABASE_URL="mongodb://mongodb:27017/timelinedb?directConnection=true"
#
# 2) MongoDB local cài máy (single-node replica set):
# DATABASE_URL="mongodb://localhost:27017/timelinedb?directConnection=true"
#
# 3) MongoDB Atlas (cloud) — đã là replica set sẵn, KHÔNG cần directConnection.
#    Nhớ chèn /timelinedb trước dấu "?":
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/timelinedb?retryWrites=true&w=majority"
